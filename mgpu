#!/usr/bin/env bash

if [ $# -lt 1 ]; then
	echo "Usage: mgpu <config_name> [dist]"
	exit 1
fi

CONFIG="$1"
CONFIG_FILE="config/${CONFIG}.json"

if [ ! -f "$CONFIG_FILE" ]; then
	echo "Error: $CONFIG_FILE not found"
	exit 1
fi

if [ "$2" = "dist" ]; then
	torchrun --standalone --nproc-per-node=2 train.py "$CONFIG_FILE"
else
	python3 train.py "$CONFIG_FILE"
fi
