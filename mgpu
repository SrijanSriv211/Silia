#!/usr/bin/env bash

if [ $# -lt 2 ]; then
	echo "Usage: mgpu <config_name> <silia|gpt> [dist]"
	exit 1
fi

CONFIG="$1"
ARCH="$2"
CONFIG_FILE="config/${CONFIG}.json"

if [ ! -f "$CONFIG_FILE" ]; then
	echo "Error: $CONFIG_FILE not found"
	exit 1
fi

if [ "$3" = "dist" ]; then
	torchrun --standalone --nproc-per-node=2 train.py "$CONFIG_FILE" "$ARCH"
else
	python3 train.py "$CONFIG_FILE" "$ARCH"
fi
