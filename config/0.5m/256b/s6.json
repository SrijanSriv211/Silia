{
    "dataset": {
        "data_division": 0.8,
        "load_from_file": true,
        "path": "data/synth-100M.bin"
    },
    "checkpoints": {
        "path": "bin/0.5m/256b/s6",
        "interval": 2000,
        "create_checkpoints": true
    },
    "model_hyperparams": {
        "vocab_size": 16384,
        "block_size": 256,
        "n_layer": 2,
        "n_head": 2,
        "n_embd": 64
    },
    "optimizer_hyperparams": {
        "eps": 1e-10,
        "beta1": 0.9,
        "beta2": 0.95,
        "weight_decay": 0.1,
        "use_muon": true,
        "momentum": 0.95
    },
    "encoder_path": "bin/cl16k.bin",
    "init_from": "scratch",
    "seed": 18,
    "gradient_accumulation_steps": 1,
    "batch_size": 8,
    "max_iters": 20000,
    "eval_interval": 2000,
    "log_interval": 200,
    "eval_iters": 200,
    "decay_lr": true,
    "lr_decay_iters": 20000,
    "learning_rate": 3e-3,
    "cooldown_frac": 0.6,
    "warmup_iters": 1000,
    "min_lr": 3e-4
}
